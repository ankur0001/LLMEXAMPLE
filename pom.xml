<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.projectmind</groupId>
    <artifactId>projectmind-parent</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <packaging>pom</packaging>

    <name>ProjectMind</name>
    <description>Persistent AI memory system for software repositories using Ollama</description>

    <modules>
        <module>projectmind-core</module>
        <module>projectmind-application</module>
        <module>projectmind-adapters</module>
        <module>projectmind-plugin-spring-boot</module>
        <module>projectmind-bootstrap</module>
    </modules>

    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>${java.version}</maven.compiler.source>
        <maven.compiler.target>${java.version}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <spring-boot.version>3.4.1</spring-boot.version>
        <picocli.version>4.6.3</picocli.version>
        <picocli-spring-boot.version>4.1.1</picocli-spring-boot.version>
        <tree-sitter.version>0.25.3</tree-sitter.version>
        <tree-sitter-java.version>0.23.4</tree-sitter-java.version>
        <tree-sitter-yaml.version>0.5.0a</tree-sitter-yaml.version>
        <tree-sitter-kotlin.version>0.3.8.1</tree-sitter-kotlin.version>
        <tree-sitter-json.version>0.24.8</tree-sitter-json.version>
        <mockwebserver.version>4.12.0</mockwebserver.version>
        <!-- Mockito pulls Byte Buddy; 1.15.x only supports through JDK 24 -->
        <byte-buddy.version>1.17.5</byte-buddy.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>com.projectmind</groupId>
                <artifactId>projectmind-core</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.projectmind</groupId>
                <artifactId>projectmind-application</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.projectmind</groupId>
                <artifactId>projectmind-adapters</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>com.projectmind</groupId>
                <artifactId>projectmind-plugin-spring-boot</artifactId>
                <version>${project.version}</version>
            </dependency>
            <dependency>
                <groupId>info.picocli</groupId>
                <artifactId>picocli</artifactId>
                <version>${picocli.version}</version>
            </dependency>
            <dependency>
                <groupId>info.picocli</groupId>
                <artifactId>picocli-spring-boot-starter</artifactId>
                <version>${picocli-spring-boot.version}</version>
            </dependency>
            <dependency>
                <groupId>io.github.bonede</groupId>
                <artifactId>tree-sitter</artifactId>
                <version>${tree-sitter.version}</version>
            </dependency>
            <dependency>
                <groupId>io.github.bonede</groupId>
                <artifactId>tree-sitter-java</artifactId>
                <version>${tree-sitter-java.version}</version>
            </dependency>
            <dependency>
                <groupId>io.github.bonede</groupId>
                <artifactId>tree-sitter-yaml</artifactId>
                <version>${tree-sitter-yaml.version}</version>
            </dependency>
            <dependency>
                <groupId>io.github.bonede</groupId>
                <artifactId>tree-sitter-kotlin</artifactId>
                <version>${tree-sitter-kotlin.version}</version>
            </dependency>
            <dependency>
                <groupId>io.github.bonede</groupId>
                <artifactId>tree-sitter-json</artifactId>
                <version>${tree-sitter-json.version}</version>
            </dependency>
            <dependency>
                <groupId>com.squareup.okhttp3</groupId>
                <artifactId>mockwebserver</artifactId>
                <version>${mockwebserver.version}</version>
            </dependency>
            <dependency>
                <groupId>net.bytebuddy</groupId>
                <artifactId>byte-buddy</artifactId>
                <version>${byte-buddy.version}</version>
            </dependency>
            <dependency>
                <groupId>net.bytebuddy</groupId>
                <artifactId>byte-buddy-agent</artifactId>
                <version>${byte-buddy.version}</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <build>
        <pluginManagement>
            <plugins>
                <plugin>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-maven-plugin</artifactId>
                    <version>${spring-boot.version}</version>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-compiler-plugin</artifactId>
                    <version>3.13.0</version>
                    <configuration>
                        <release>${java.version}</release>
                        <parameters>true</parameters>
                    </configuration>
                </plugin>
                <plugin>
                    <groupId>org.apache.maven.plugins</groupId>
                    <artifactId>maven-surefire-plugin</artifactId>
                    <version>3.5.2</version>
                    <configuration>
                        <!-- Allow Mockito/Byte Buddy on JDK versions newer than their GA support -->
                        <argLine>-Dnet.bytebuddy.experimental=true</argLine>
                    </configuration>
                </plugin>
            </plugins>
        </pluginManagement>
    </build>
</project>
